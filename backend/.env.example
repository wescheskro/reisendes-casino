# ============================================
# Reisendes Casino – Umgebungsvariablen
# ============================================
# Kopiere diese Datei als .env und fülle die Werte aus:
#   cp .env.example .env

# JWT Secret (ändere das in Produktion!)
JWT_SECRET=reisendes-casino-secret-change-in-production

# ---- E-Mail Verifizierung (Gmail) ----
# 1. Gehe zu https://myaccount.google.com/apppasswords
# 2. Erstelle ein App-Passwort für "Mail"
# 3. Trage die E-Mail und das 16-Zeichen App-Passwort hier ein
EMAIL_USER=dein-casino@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ---- Google Sign-In ----
# 1. Gehe zu https://console.cloud.google.com/
# 2. Erstelle ein Projekt oder wähle ein bestehendes
# 3. APIs & Dienste → Anmeldedaten → OAuth 2.0-Client-ID erstellen
# 4. Typ: Webanwendung
# 5. Autorisierte JavaScript-Ursprünge: http://localhost:3000 (+ deine Domain)
# 6. Kopiere die Client-ID hierher
GOOGLE_CLIENT_ID=123456789-xxxxxxxx.apps.googleusercontent.com
